      ],
      "runbook": "docs/runbooks/st-031-source-aware-incident-response.md",
      "remediation_action": "stabilize_summarize_execution_choose_confidence_or_rollback_then_replay_after_fix",
      "diagnostic_links": {
        "dashboard_path": "docs/runbooks/st-011-baseline-dashboards.json",
        "dashboard_panel_id": "pipeline-stage-outcomes",
        "supporting_paths": ["docs/runbooks/st-031-source-aware-dashboard.json"]
      }
    },
    {
      "alert_id": "st031-stale-pipeline-dlq-backlog-warning",
      "alert_class": "stale_pipeline_dlq_backlog",
      "severity": "warning",
      "signal": "age_with_backlog",
      "signal_source": {
        "primary_metric": "councilsense_pipeline_dlq_oldest_age_seconds",
        "primary_filters": {
          "outcome": "oldest_age"
        },
        "gating_metric": "councilsense_pipeline_dlq_backlog_count",
        "gating_filters": {
          "outcome": "backlog"
        }
      },
      "threshold": {
        "operator": ">=",
        "value": 3600,
        "unit": "seconds",
        "for": "PT30M",
        "evaluation_window": "PT30M",
        "gating_conditions": [
          {
            "metric": "councilsense_pipeline_dlq_backlog_count",
            "operator": ">=",
            "value": 2,
            "unit": "entries"
          }
        ],
        "environment_overrides": {
          "local": {
            "value": 1800,
            "gating_conditions": [
              {
                "metric": "councilsense_pipeline_dlq_backlog_count",
                "operator": ">=",
                "value": 1,
                "unit": "entries"
              }
            ]
          }
        }
      },
      "owner_routing": {
        "primary_role": "ops-pipeline-oncall",
        "secondary_role": "backend-oncall",
        "escalate_to": "platform-owner",
        "escalation_sla": "PT30M"
      },
      "noise_controls": {
        "dedupe_key_fields": [
          "alert_id",
          "environment",
          "city_id",
          "source_id",
          "stage"
        ],
        "dedupe_window": "PT2H",
        "minimum_sample_count": 1,
        "suppression_conditions": ["active_dlq_replay_batch"]
      },
      "payload_context_fields": [
        "dlq_key",
        "terminal_reason",
        "retry_policy_version",
        "backlog_count",
        "oldest_age_seconds",
        "dlq_status",
        "error_code",
        "error_type"
      ],
      "runbook": "docs/runbooks/st-031-source-aware-incident-response.md",
      "remediation_action": "drain_source_scoped_dlq_backlog_with_audited_replay_batches",
      "diagnostic_links": {
        "dashboard_path": "docs/runbooks/st-031-source-aware-dashboard.json",
        "dashboard_panel_id": "st031-pipeline-dlq-oldest-age-by-source",
        "supporting_paths": ["docs/runbooks/st-029-pipeline-dlq-contract.md"]
      }
    },
    {
      "alert_id": "st031-stale-pipeline-dlq-backlog-critical",
      "alert_class": "stale_pipeline_dlq_backlog",
      "severity": "critical",
      "signal": "age_with_backlog",
      "signal_source": {
        "primary_metric": "councilsense_pipeline_dlq_oldest_age_seconds",
        "primary_filters": {
          "outcome": "oldest_age"
        },
        "gating_metric": "councilsense_pipeline_dlq_backlog_count",
        "gating_filters": {
          "outcome": "backlog"
        }
      },
      "threshold": {
        "operator": ">=",
        "value": 10800,
        "unit": "seconds",
        "for": "PT30M",
        "evaluation_window": "PT30M",
        "gating_conditions": [
          {
            "metric": "councilsense_pipeline_dlq_backlog_count",
            "operator": ">=",
            "value": 3,
            "unit": "entries"
          }
        ],
        "environment_overrides": {
          "local": {
            "value": 3600,
            "gating_conditions": [
              {
                "metric": "councilsense_pipeline_dlq_backlog_count",
                "operator": ">=",
                "value": 2,
                "unit": "entries"
              }
            ]
          }
        }
      },
      "owner_routing": {
        "primary_role": "ops-pipeline-oncall",
        "secondary_role": "backend-oncall",
        "escalate_to": "platform-owner",
        "escalation_sla": "PT30M"
      },
      "noise_controls": {
        "dedupe_key_fields": [
          "alert_id",
          "environment",
          "city_id",
          "source_id",
          "stage"
        ],
        "dedupe_window": "PT2H",
        "minimum_sample_count": 1,
        "suppression_conditions": ["active_dlq_replay_batch"]
      },
      "payload_context_fields": [
        "dlq_key",
        "terminal_reason",
        "retry_policy_version",
        "backlog_count",
        "oldest_age_seconds",
        "dlq_status",
        "error_code",
        "error_type"
      ],
      "runbook": "docs/runbooks/st-031-source-aware-incident-response.md",
      "remediation_action": "drain_source_scoped_dlq_backlog_with_audited_replay_batches",
      "diagnostic_links": {
        "dashboard_path": "docs/runbooks/st-031-source-aware-dashboard.json",
        "dashboard_panel_id": "st031-pipeline-dlq-oldest-age-by-source",
        "supporting_paths": ["docs/runbooks/st-029-pipeline-dlq-contract.md"]
      }
    }
  ]
