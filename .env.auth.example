# Managed auth (Cognito + Google) callback/logout URL wiring
# Local callback/logout values are documented in docs/runbooks/auth-google-local-callbacks.md

AUTH_GOOGLE_ENABLED=true
AUTH_SOCIAL_PROVIDERS=google

AUTH_CALLBACK_URL_LOCAL=http://localhost:3000/auth/callback
AUTH_LOGOUT_URL_LOCAL=http://localhost:3000/

AUTH_CALLBACK_URL_DEV=https://dev.councilsense.app/auth/callback
AUTH_LOGOUT_URL_DEV=https://dev.councilsense.app/
